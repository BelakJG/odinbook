
<div class="user-post">
    <%= render "post", post: @post %>
</div>

<div>
    <h3>Comments</h3>
    <div id="new_comment">
        <%= turbo_frame_tag "comment_form" %>
        <%= link_to "New Comment", new_post_comment_path(@post), data: {turbo_frame: "comment_form"}%>
    </div>
</div>

<div id="comments">
    <%= render @comments %>
</div>