<div class="profile-header">
    <h1>Profile for <%= @user.email %></h1>
    <div class="user-avatar">
        <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, width: 150 %>
        <% end %>
        <% if @user == current_user %>
            <%= form_with model: current_user, local: true, html: { multipart: true } do |f| %>
                <div>
                    <%= f.label :avatar, "Update profile picture" %><br>
                    <%= f.file_field :avatar %>
                </div>
                <div>
                    <%= f.submit "Upload Avatar" %>
                </div>
            <% end %>
        <% end %>
    </div>
    <% if user_signed_in? && current_user != @user %>
        <% unless current_user.following?(@user) %>
            <%= button_to "follow", follow_user_path(@user), method: :post %>
        <% else %>
            <%= button_to "unfollow", unfollow_user_path(@user), method: :delete %>
        <% end %>
    <% end %>
</div>


<div id="posts" class="user-posts">
    <%= render @posts %>
</div>